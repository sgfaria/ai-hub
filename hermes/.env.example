HERMES_VERSION=latest
TZ=America/Sao_Paulo
AI_HUB_ROOT=/srv/ai-hub
AI_HUB_NETWORK=ai-network

# Gere com: openssl rand -hex 32
API_SERVER_KEY=troque-por-um-token-longo-e-aleatorio

# Credenciais do dashboard; use valores exclusivos.
HERMES_DASHBOARD=1
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=troque-por-uma-senha-forte
HERMES_DASHBOARD_BASIC_AUTH_SECRET=troque-por-outro-token-longo-e-aleatorio

# A cobrança da API é separada da assinatura do ChatGPT.
OPENAI_API_KEY=sk-proj-substitua
