# Copie para ".env", preencha e rode: chmod 600 .env
# Este arquivo fica FORA do controle de versão (adicione ".env" ao .gitignore).

### --- Config não sensível ---
HERMES_LLM_BASE_URL=https://api.openai.com/v1
HERMES_LLM_MODEL=gpt-4o-mini
HERMES_PLATFORM=telegram
HERMES_MEMORY_PERSISTENT=true
HERMES_SKILLS_AUTOGEN=true
TZ=America/Sao_Paulo

HERMES_CPU_LIMIT=4
HERMES_MEM_LIMIT=4G

HERMES_HOST_DATA_DIR=/srv/hermes/data

### --- Segredos (troque pelos valores reais) ---
HERMES_BOT_TOKEN=coloque_aqui_o_token_do_telegram
HERMES_LLM_API_KEY=coloque_aqui_a_api_key_do_llm
