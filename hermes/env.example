# Copie para ".env" e ajuste os valores.
# NUNCA coloque tokens ou API keys aqui — use Swarm Secrets
# (CLI: docker secret create / Portainer: menu Swarm > Secrets).

# Backend do LLM
HERMES_LLM_BASE_URL=https://api.openai.com/v1
HERMES_LLM_MODEL=gpt-4o-mini

# Plataforma de mensageria (telegram, discord, whatsapp...)
HERMES_PLATFORM=telegram

# Memória persistente e autogeração de skills
HERMES_MEMORY_PERSISTENT=true
HERMES_SKILLS_AUTOGEN=true

# Timezone
TZ=America/Sao_Paulo

# Limites de recursos do container
HERMES_CPU_LIMIT=4
HERMES_MEM_LIMIT=4G

# Diretório no HOST onde a memória/skills do Hermes serão gravadas
# (crie a pasta antes do deploy: sudo mkdir -p /srv/hermes/data)
HERMES_HOST_DATA_DIR=/srv/hermes/data

# Hostname do node do Swarm onde esse diretório existe
# (descubra com: docker node ls)
HERMES_NODE_HOSTNAME=meu-servidor-hostname
